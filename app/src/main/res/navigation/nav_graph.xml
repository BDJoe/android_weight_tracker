<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    app:startDestination="@+id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.josephlimbert.weighttracker.ui.home.HomeFragment"
        android:label="Weight Tracker"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_sign_in"
            app:destination="@id/navigation_sign_in"/>
    </fragment>

    <fragment
        android:id="@+id/navigation_history"
        android:name="com.josephlimbert.weighttracker.ui.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history"/>

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.josephlimbert.weighttracker.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings"/>

    <fragment
        android:id="@+id/navigation_sign_in"
        android:name="com.josephlimbert.weighttracker.ui.signin.SignInFragment"
        android:label="Sign In"
        tools:layout="@layout/fragment_sign_in">
        <action
            android:id="@+id/action_sign_in_to_home"
            app:destination="@id/navigation_home"/>
    </fragment>

</navigation>